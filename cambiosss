<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SeguroToy — Comparador de seguros</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;500;600;700;800;900&family=Nunito:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root{
  --st-primary:#002CC3;--st-primary-dark:#0020A0;--st-accent:#FFB800;
  --st-bg:#FFFFFF;--st-surface:#F6F7F9;--st-border:#E6E8EC;
  --st-text:#10131A;--st-text-muted:#4B5563;--st-success:#1E9E6A;
  --st-font:"Nunito Sans",system-ui,sans-serif;--st-radius-pill:999px;
  --st-shadow:0 2px 8px rgba(16,24,40,.06),0 8px 24px rgba(16,24,40,.06);
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:var(--st-font);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:48px 24px;
  background:radial-gradient(1200px 600px at 78% -10%,rgba(0,44,195,.10),transparent 60%),
    radial-gradient(900px 600px at 10% 110%,rgba(0,44,195,.06),transparent 55%),
    linear-gradient(180deg,#EEF1F6,#E4E8EF);}
.stage{display:flex;flex-direction:column;align-items:center;gap:26px}
.phone{position:relative;width:392px;height:auto;background:linear-gradient(150deg,#2a2d33,#0c0d10 55%,#26282d);
  border-radius:62px;padding:14px;
  box-shadow:0 0 0 2px #000,0 2px 2px 3px rgba(255,255,255,.10) inset,0 50px 90px -30px rgba(16,24,40,.55),0 10px 30px -10px rgba(0,44,195,.25);}
.phone::before,.phone::after{content:"";position:absolute;background:#16181c;border-radius:3px}
.phone::before{left:-3px;top:170px;width:3px;height:64px;box-shadow:0 84px 0 #16181c,0 158px 0 #16181c}
.phone::after{right:-3px;top:210px;width:3px;height:96px}
.screen{position:relative;width:100%;background:var(--st-bg);border-radius:48px;overflow:hidden;display:flex;flex-direction:column;min-height:820px}
.island{position:absolute;top:13px;left:50%;transform:translateX(-50%);width:122px;height:34px;background:#000;border-radius:20px;z-index:40}
.island::after{content:"";position:absolute;right:14px;top:50%;transform:translateY(-50%);width:9px;height:9px;border-radius:50%;background:radial-gradient(circle at 35% 35%,#1b3a5c,#06101c)}
.statusbar{height:50px;flex:0 0 50px;display:flex;align-items:center;justify-content:space-between;padding:0 30px 0 34px;font-weight:800;font-size:15px;color:var(--st-text);z-index:30}
.status-ic{display:flex;align-items:center;gap:7px}
.app{flex:1;display:flex;flex-direction:column;overflow:hidden}
.topbar{display:flex;align-items:center;justify-content:space-between;padding:16px 22px 2px}
.brand{display:flex;align-items:center;gap:9px;font-weight:900;font-size:20px;letter-spacing:-.4px;color:var(--st-text)}
.brand .mark{width:28px;height:28px;border-radius:9px;background:var(--st-primary);display:grid;place-items:center;color:#fff;font-weight:900;font-size:15px;box-shadow:0 4px 10px -2px rgba(0,44,195,.5)}
.brand b{color:var(--st-primary)}
.brand-logo{height:26px;width:auto;display:block}
.brand-logo.hero-logo{height:32px}
.menu{width:40px;height:40px;border-radius:12px;background:var(--st-surface);border:1px solid var(--st-border);display:grid;place-items:center}
.menu span{display:block;width:16px;height:2.2px;background:var(--st-text);border-radius:2px;margin:2px 0}
.hero-copy{padding:18px 22px 2px}
.eyebrow{display:inline-flex;align-items:center;gap:7px;background:rgba(0,44,195,.08);color:var(--st-primary);font-weight:800;font-size:11px;letter-spacing:.3px;text-transform:uppercase;padding:5px 11px;border-radius:var(--st-radius-pill);margin-bottom:11px}
.eyebrow .dot{width:7px;height:7px;border-radius:50%;background:var(--st-success);box-shadow:0 0 0 3px rgba(30,158,106,.18)}
h1{font-weight:900;font-size:26px;line-height:1.06;letter-spacing:-.9px;color:var(--st-text)}
h1 .accent{color:var(--st-primary);position:relative;white-space:nowrap}
h1 .accent::after{content:"";position:absolute;left:0;right:0;bottom:2px;height:8px;background:rgba(0,44,195,.16);border-radius:4px;z-index:-1}
.sub{margin-top:10px;font-size:15px;line-height:1.2;color:#374151;font-weight:600;max-width:300px}

/* ----- botones de cobertura (Opción 3) ----- */
.opts{padding:14px 18px 8px;display:flex;flex-direction:column;gap:11px}
.opts-label{display:flex;align-items:center;gap:8px;font-size:11px;font-weight:800;letter-spacing:.4px;text-transform:uppercase;color:var(--st-text-muted);padding-left:4px}
.opts-label::after{content:"";flex:1;height:1px;background:var(--st-border)}
.cov{position:relative;display:flex;align-items:center;justify-content:space-between;gap:12px;text-decoration:none;cursor:pointer;
  background:var(--st-primary);color:#fff;border-radius:14px;padding:11px 14px;
  box-shadow:0 6px 16px -8px rgba(0,44,195,.5);transition:transform .15s ease,box-shadow .15s ease}
.cov:hover{transform:translateY(-1px);box-shadow:0 10px 20px -8px rgba(0,44,195,.55)}
.cov.feat{box-shadow:0 0 0 2px rgba(0,44,195,.28),0 8px 18px -8px rgba(0,44,195,.5)}
.cov-l{min-width:0}
.cov-name{font-size:15px;font-weight:900;letter-spacing:-.3px;line-height:1.1}
.cov-sup{font-size:11px;font-weight:700;color:rgba(255,255,255,.8);line-height:1.2;margin-top:2px}
.cov-r{display:flex;align-items:center;gap:9px;flex:0 0 auto}
.cov-price{text-align:right;line-height:1.18}
.cov-price .big{font-size:13.5px;font-weight:900;white-space:nowrap}
.cov-price .small{display:block;font-size:10px;font-weight:700;color:rgba(255,255,255,.78);white-space:nowrap}
.cov-go{width:26px;height:26px;border-radius:50%;background:rgba(255,255,255,.18);display:grid;place-items:center}
.cov .badge{position:absolute;top:-8px;right:14px;background:var(--st-accent);color:#3a2a00;font-size:9px;font-weight:900;letter-spacing:.3px;text-transform:uppercase;padding:3px 9px;border-radius:var(--st-radius-pill);box-shadow:0 4px 10px -3px rgba(0,0,0,.25)}

.photo-wrap{position:relative;height:252px;flex:none;display:flex;align-items:flex-end;justify-content:center;overflow:hidden;margin-top:4px}
.photo{position:absolute;inset:0;z-index:1;width:100%;height:100%;object-fit:contain;object-position:center bottom}
.photo-wrap::before{content:"";position:absolute;left:0;right:0;top:0;height:28px;z-index:2;background:linear-gradient(180deg,#fff,rgba(255,255,255,0))}

/* ----- bloque: Tu seguro en 3 fotos ----- */
.howto{background:#EFEEFB;padding:14px 22px 16px;text-align:center;position:relative}
.howto h3{font-size:19px;font-weight:900;letter-spacing:-.4px;color:#16187A}
.howto .ht-sub{font-size:14px;font-weight:700;color:#4D5174;margin-top:4px}
.howto .ht-orange{font-size:13.5px;font-weight:800;color:#F26A1E;margin-top:8px}
.ht-stage{display:flex;align-items:center;justify-content:center;gap:14px;margin:8px 0 2px}
.ht-arrow{width:36px;height:36px;border-radius:50%;background:#fff;border:none;display:grid;place-items:center;color:var(--st-text);cursor:pointer;box-shadow:0 6px 16px -6px rgba(22,24,122,.25);flex:0 0 36px}
.ht-circle{position:relative;width:94px;height:94px;border-radius:50%;background:var(--st-primary);display:grid;place-items:center;box-shadow:0 14px 26px -10px rgba(0,44,195,.5)}
.howto .doc{width:40px;height:40px}
.ht-circle .doc{color:#fff}
.ht-badge{position:absolute;top:6px;right:6px;width:34px;height:34px;border-radius:50%;background:#fff;display:grid;place-items:center;font-size:15px;font-weight:900;color:var(--st-primary);box-shadow:0 4px 10px -3px rgba(0,0,0,.2)}
.ht-foot{margin-top:6px}
.ht-foot h4{font-size:18px;font-weight:900;letter-spacing:-.4px;color:var(--st-primary)}
.ht-foot p{font-size:13px;font-weight:700;color:#4D5174;line-height:1.3;margin-top:3px}
.ht-dots{display:flex;align-items:center;justify-content:center;gap:7px;margin-top:8px}
.ht-dots i{width:8px;height:8px;border-radius:50%;background:#C9C8E6}
.ht-dots i.on{width:22px;border-radius:5px;background:var(--st-primary)}

/* ----- Por qué elegirnos ----- */
.why{background:#EFEEFB;padding:6px 22px 34px;text-align:center}
.why .eyebrow2{color:#F26A1E;font-weight:900;font-size:13px;letter-spacing:.2px;margin-bottom:4px}
.why h3{font-size:25px;font-weight:900;color:var(--st-primary);letter-spacing:-.6px;line-height:1.08}
.why h3 .why-logo{height:34px;width:auto;display:inline-block;margin-top:12px;vertical-align:middle}
.why .why-sub{font-size:15px;font-weight:700;color:#4D5174;margin-top:12px;line-height:1.35}
.why-list{display:flex;flex-direction:column;gap:13px;margin-top:22px}
.why-card{background:#fff;border:1px solid #ECEBF7;border-radius:18px;padding:17px 18px;display:flex;gap:14px;align-items:flex-start;text-align:left;box-shadow:var(--st-shadow)}
.why-ic{flex:0 0 auto;color:var(--st-primary);margin-top:1px}
.why-tx{min-width:0}
.why-tt{font-size:17px;font-weight:900;color:var(--st-primary);line-height:1.12;letter-spacing:-.3px}
.why-dc{font-size:12.5px;font-weight:600;color:#4D5174;margin-top:6px;line-height:1.42}
.ht-cta{display:inline-flex;align-items:center;gap:8px;margin-top:16px;background:var(--st-primary);color:#fff;font-weight:900;font-size:14.5px;padding:12px 24px;border:none;border-radius:999px;box-shadow:0 12px 22px -10px rgba(0,44,195,.5);cursor:pointer;letter-spacing:-.2px}
.partners{background:var(--st-bg);padding:30px 22px 6px;text-align:center}
.sec-h{font-size:21px;font-weight:900;color:var(--st-primary);letter-spacing:-.4px}
.sec-sub{font-size:14px;font-weight:700;color:#4D5174;margin-top:6px;line-height:1.35}
.plogos{display:flex;gap:14px;margin-top:20px}
.plogo{flex:1;background:#F6F7FB;border:1px solid #ECEBF7;border-radius:16px;height:76px;display:grid;place-items:center;font-weight:900;font-size:25px;letter-spacing:-.5px}
.plogo-sura{color:#0A2A6B}
.plogo-mapfre{color:#E2001A}
.ssrp{display:inline-flex;align-items:center;gap:10px;margin-top:22px;max-width:262px;background:#6C5CE7;color:#fff;font-weight:800;font-size:13.5px;line-height:1.25;padding:13px 22px;border-radius:18px;box-shadow:0 14px 26px -12px rgba(108,92,231,.55);text-align:left}
.ssrp svg{flex:0 0 auto}
.tmnls{background:var(--st-bg);padding:24px 18px 32px;text-align:center}
.tmnls-h{font-size:22px;font-weight:900;color:var(--st-primary);letter-spacing:-.5px}
.tmnls-h .toy{color:#F26A1E}
.tcards{display:flex;gap:13px;margin-top:20px;align-items:stretch}
.tcard{flex:1;min-width:0;background:#fff;border:1px solid #ECEBF7;border-radius:18px;padding:16px 14px;text-align:left;box-shadow:var(--st-shadow);display:flex;flex-direction:column;gap:7px}
.tava{width:42px;height:42px;border-radius:50%;color:#fff;font-weight:900;font-size:18px;display:grid;place-items:center}
.tstars{color:#FFB800;font-size:13px;letter-spacing:2px}
.tcard .tt{font-size:15px;font-weight:900;color:var(--st-primary);letter-spacing:-.2px;line-height:1.1}
.tcard .tq{font-size:11.5px;font-weight:600;color:#444A5B;line-height:1.4;font-style:italic}
.tcard .tname{font-size:11px;font-weight:800;color:var(--st-text);margin-top:auto;padding-top:2px}
.home-ind{position:absolute;bottom:8px;left:50%;transform:translateX(-50%);width:134px;height:5px;border-radius:3px;background:#0b0c0f;opacity:.85;z-index:30}

/* ----- pantalla: Daños a terceros ----- */
.t-head{display:flex;align-items:center;gap:11px;padding:6px 18px 2px}
.t-back{width:36px;height:36px;border-radius:11px;background:var(--st-surface);border:1px solid var(--st-border);display:grid;place-items:center;cursor:pointer;color:var(--st-text);flex:0 0 36px}
.t-htitle{font-size:16px;font-weight:900;color:var(--st-text);letter-spacing:-.3px}
.t-photo{width:68%;display:block;margin:8px auto 0}
.t-copy{padding:12px 26px 0;text-align:center}
.t-copy h2{font-size:16px;font-weight:900;color:var(--st-primary);letter-spacing:-.2px;line-height:1.22}
.t-copy .t-only{font-size:15px;font-weight:900;color:var(--st-primary);margin-top:7px}
.t-circles{display:flex;justify-content:center;gap:14px;padding:16px 20px 8px}
.t-circle{display:flex;flex-direction:column;align-items:center;gap:8px;flex:1}
.t-circle .c{width:52px;height:52px;border-radius:50%;background:#EDEDF6;display:grid;place-items:center;color:#53587A;transition:transform .15s ease}
.t-circle.on .c{background:var(--st-primary);color:#fff;box-shadow:0 9px 18px -8px rgba(0,44,195,.55)}
.t-circle span{font-size:11.5px;font-weight:900;color:var(--st-primary);line-height:1.1;text-align:center}

/* ----- comparación de grupos (terceros) ----- */
.tp{padding:20px 20px 6px;background:#fff}
.tp-h{font-size:22px;font-weight:900;color:var(--st-primary);text-align:center;line-height:1.12;letter-spacing:-.5px}
.tp-h .or{color:#F26A1E}
.tp-sub{text-align:center;font-size:13px;font-weight:800;color:var(--st-primary);margin-top:8px}
.steps{display:flex;justify-content:space-between;align-items:flex-start;margin:14px 6px 0;position:relative}
.steps::before{content:"";position:absolute;top:11px;left:13%;right:13%;height:2px;background:#E2E3EF;z-index:0}
.steps::after{content:"";position:absolute;top:11px;left:13%;width:24%;height:2px;background:var(--st-primary);z-index:0}
.step{display:flex;flex-direction:column;align-items:center;gap:6px;flex:1;position:relative;z-index:1}
.step .num{width:24px;height:24px;border-radius:50%;display:grid;place-items:center;font-size:11px;font-weight:900;background:#fff;border:2px solid #D5D7E6;color:#53587A}
.step.done .num{background:var(--st-primary);border-color:var(--st-primary);color:#fff}
.step .lb{font-size:9px;font-weight:800;color:#53587A;text-align:center;line-height:1.05}
.step.done .lb{color:var(--st-primary)}
.choose{text-align:center;font-size:18px;font-weight:900;color:var(--st-primary);margin-top:20px;line-height:1.2}
.choose-u{width:46px;height:3px;background:#F26A1E;border-radius:2px;margin:9px auto 2px}
.toggle{display:flex;width:fit-content;background:#EDEDF6;border-radius:999px;padding:3px;margin:12px auto 0}
.toggle button{border:none;background:transparent;font-family:var(--st-font);font-size:11px;font-weight:800;color:#494A72;padding:6px 14px;border-radius:999px;cursor:pointer;white-space:nowrap}
.toggle button.on{background:#fff;color:var(--st-text);box-shadow:0 2px 6px rgba(16,24,40,.12)}
.payswitch{display:flex;width:fit-content;background:#EDEDF6;border-radius:999px;padding:2px;margin:0 auto}
.payswitch button{border:none;background:transparent;font-family:var(--st-font);font-size:10px;font-weight:800;color:#494A72;padding:5px 12px;border-radius:999px;cursor:pointer;white-space:nowrap;letter-spacing:-.1px}
.payswitch button.on{background:#fff;color:var(--st-text);box-shadow:0 2px 6px rgba(16,24,40,.12)}
.plan-title{text-align:center;padding:0 22px;margin-top:44px}
.plan-title .lead{display:block;font-size:14.5px;font-weight:800;color:var(--st-text-muted);margin-bottom:6px}
.plan-title h2{font-size:25px;font-weight:900;color:var(--st-primary);line-height:1.16;letter-spacing:-.4px}
.plan-title .plan-note{font-size:13.5px;font-weight:700;color:var(--st-text-muted);margin-top:7px}
.paylogos{display:flex;align-items:center;justify-content:center;gap:16px;margin-top:24px}
.pl-visa{font-family:Arial,Helvetica,sans-serif;font-style:italic;font-weight:900;font-size:17px;color:#1A1F71;letter-spacing:-.6px}
.pl-mc{position:relative;display:inline-block;width:34px;height:21px}
.pl-mc i{position:absolute;top:0;width:21px;height:21px;border-radius:50%}
.pl-mc i:first-child{left:0;background:#EB001B}
.pl-mc i:last-child{right:0;background:#F79E1B;mix-blend-mode:multiply}
.pl-yappy{font-weight:900;font-size:16px;color:#19C3C9;letter-spacing:-.3px}
.pcards{display:flex;flex-direction:column;gap:12px;margin-top:18px}
.pcard{position:relative;background:var(--st-primary);border-radius:16px;padding:0;color:#fff;box-shadow:0 10px 22px -12px rgba(0,44,195,.55)}
.pc-row{display:flex;align-items:center;justify-content:space-between;gap:10px;padding:11px 14px;cursor:pointer}
.pc-l{min-width:0;line-height:1.06}
.pc-r{display:flex;align-items:center;gap:9px;flex:0 0 auto}
.pc-chev{transition:transform .2s ease;opacity:.85}
.pcard.open .pc-chev{transform:rotate(180deg)}
.pcard.feat{box-shadow:0 0 0 2px rgba(255,255,255,.4),0 12px 24px -12px rgba(0,44,195,.55)}
.pc-top{display:flex;justify-content:space-between;align-items:flex-start;gap:10px}
.pc-name{font-size:15px;font-weight:900;color:#fff;letter-spacing:-.3px;line-height:1.05}
.pc-name small{display:block;font-size:11.5px;font-weight:800;color:rgba(255,255,255,.78);margin-top:2px}
.pc-price{text-align:right;line-height:1.05}
.pc-price .h{font-size:10px;font-weight:800;color:rgba(255,255,255,.7);text-transform:uppercase;letter-spacing:.3px}
.pc-price .big{font-size:17px;font-weight:900;color:#fff;letter-spacing:-.4px}
.pc-price .mo{font-size:9px;font-weight:800;color:rgba(255,255,255,.82);margin-top:1px}
.pc-mid{display:flex;align-items:center;gap:9px;margin-top:12px}
.pc-ins{display:inline-flex;gap:5px;background:rgba(255,255,255,.15);padding:5px 7px;border-radius:9px}
.pc-ins i{width:14px;height:18px;border-radius:4px 4px 6px 6px;display:block}
.pc-cnt{display:block;margin-top:2px;font-size:10px;font-weight:700;color:rgba(255,255,255,.72)}
.pc-foot{display:flex;justify-content:flex-end;border-top:1px solid rgba(255,255,255,.2);margin-top:12px;padding-top:11px}
.pc-link{font-size:13px;font-weight:900;color:#fff;display:inline-flex;align-items:center;gap:5px;cursor:pointer}
.pc-badge{position:absolute;top:-10px;left:16px;background:var(--st-accent);color:#3a2a00;font-size:9.5px;font-weight:900;text-transform:uppercase;letter-spacing:.3px;padding:4px 10px;border-radius:999px;display:inline-flex;align-items:center;gap:4px;box-shadow:0 4px 10px -3px rgba(0,0,0,.25)}
.pc-badge.rec{background:#F26A1E;color:#fff}
.pays{text-align:center;margin:24px 0 6px}
.pays .plb{font-size:11px;font-weight:800;color:#53587A;letter-spacing:.5px}
.pays .prow{display:flex;align-items:center;justify-content:center;gap:20px;margin-top:13px}
.pay-visa{font-style:italic;font-weight:900;font-size:19px;color:#1A1F71;letter-spacing:-.5px}
.pay-mc{position:relative;width:36px;height:22px}
.pay-mc i{position:absolute;top:0;width:22px;height:22px;border-radius:50%}
.pay-mc i:first-child{left:0;background:#EB001B}
.pay-mc i:last-child{right:0;background:#F79E1B;mix-blend-mode:multiply}
.pay-yappy{font-weight:900;font-size:18px;color:#5B4FE0;letter-spacing:-.3px}
.t-home{display:flex;align-items:center;justify-content:center;gap:7px;width:100%;margin:18px 0 2px;background:none;border:none;color:var(--st-primary);font-family:var(--st-font);font-size:13px;font-weight:900;cursor:pointer}

/* ----- propuesta reordenada (terceros) ----- */
.t-ban{position:relative;height:250px;margin:10px 16px 0;border-radius:18px;overflow:hidden}
.t-ban img{width:100%;height:100%;object-fit:cover;object-position:center 20%;display:block}
.t-ban .scrim{position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,18,75,0) 30%,rgba(0,16,70,.5) 58%,rgba(0,11,55,.9) 100%)}
.t-ban-ov{position:absolute;left:0;right:0;bottom:0;padding:0 18px 16px;color:#fff;text-align:center}
.t-ban-ov h2{font-size:16px;font-weight:900;line-height:1.22}
.t-ban-docs{display:flex;justify-content:center;gap:30px;margin-top:12px}
.t-ban-doc{display:flex;flex-direction:column;align-items:center;gap:5px;color:#fff}
.t-ban-doc span{font-size:11px;font-weight:800}
.fchips{display:flex;gap:7px;padding:12px 16px 0;justify-content:center}
.fchip{background:#F2F1FB;border-radius:999px;padding:6px 13px;font-size:11.5px;font-weight:800;color:var(--st-primary)}
