  function annualOf(L,ins,asist){var a=Math.round(ins.base*L.mult);return asist==='sin'?Math.round(a*0.87):a;}
  function price(annual){
    if(st.pay==='m') return {a:'$'+(annual/10).toFixed(2), u:'x mes · 10 pagos', s:annual/10};
