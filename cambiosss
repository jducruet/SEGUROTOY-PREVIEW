      '<div class="best-cat">Categoría</div>'+
      row(IC.precio,'Mejor precio',wp, price(annualOf(L,wp)).a, false)+
      row(IC.asist,'Mejor asistencia',wa, wa.asist+' de 7', true)+
      row(IC.grua,'Mejor grúa',wg, '$'+wg.grua, false)+
      row(IC.amb,'Mejor ambulancia',wm, '$'+wm.amb, false)+
    '</div>';
  }

  var INSORD=['fedpa','is','optima','assa','regional','mapfre','sura'];
  var NAMES={fedpa:'Fedpa',is:'IS',optima:'\u00d3ptima',assa:'ASSA',regional:'Regional',mapfre:'Mapfre',sura:'SURA'};
  var TROPHY=ic('<path d="M8 4h8v4a4 4 0 0 1-8 0z"/><path d="M8 6H5v1a3 3 0 0 0 3 3M16 6h3v1a3 3 0 0 0-3 3"/><path d="M12 12v3M9 19h6M10 19l.4-2h3.2l.4 2"/>');
  var SCALE=ic('<path d="M12 4v16M7 20h10M5 7h14M12 5l-5 2 5 0M12 5l5 2-5 0"/><path d="M7 7l-2.5 5h5zM17 7l-2.5 5h5z"/>');
  var COIN=ic('<circle cx="12" cy="12" r="8"/><path d="M12 8v8M9.5 9.5c.7-.8 1.6-1 2.5-1 1.3 0 2 .7 2 1.6 0 2-4.5 1.2-4.5 3.3 0 .9.8 1.6 2 1.6.9 0 1.8-.3 2.5-1"/>');
  var CHR='<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>';
  var CHV_SM='<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>';
  var GCK='<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#1D9E75" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5 9-11"/></svg>';
  var CKMARK='<span class="asw-ck"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5 9-11"/></svg></span>';

  var ASIST=[
    {n:'Gr\u00faa por colisi\u00f3n', g:'Asistencia vial', v:['Incluido','Incluido','Incluido','Incluido','Incluido','Incluido','Incluido']},
    {n:'Gr\u00faas por desperfectos mec\u00e1nicos', g:'Asistencia vial', v:['Hasta 150 a\u00f1o calendario','Hasta 150 a\u00f1o calendario','Hasta 150 o 3 por a\u00f1o','Hasta 150 o 3 por a\u00f1o','Hasta 150 a\u00f1o calendario','Hasta 150 o 3 por a\u00f1o','Hasta 150 o 3 por a\u00f1o']},
    {n:'Auto de alquiler por robo', g:'Asistencia vial', v:['No incluido','30 d\u00edas, 72 h despu\u00e9s','30 d\u00edas, 72 h despu\u00e9s','30 d\u00edas, 72 h despu\u00e9s','30 d\u00edas, 72 h despu\u00e9s','30 d\u00edas, 72 h despu\u00e9s','30 d\u00edas, 72 h despu\u00e9s']},
    {n:'0% depreciaci\u00f3n por p\u00e9rdida total', g:'Asistencia vial', v:['No incluido','No incluido','Incluido solo primer a\u00f1o','Incluido solo primer a\u00f1o','No incluido','Incluido solo primer a\u00f1o','Incluido solo primer a\u00f1o']},
    {n:'Servicio de ambulancia', g:'Asistencia vial', v:['24 horas todo el a\u00f1o','24 horas todo el a\u00f1o','24 horas todo el a\u00f1o','24 horas todo el a\u00f1o','24 horas todo el a\u00f1o','24 horas todo el a\u00f1o','24 horas todo el a\u00f1o']},
    {n:'Cerrajero', g:'Asistencia vial', v:['Hasta 100','Hasta 100','Hasta 100','Hasta 100','Hasta 100','Hasta 100','Hasta 100']},
    {n:'Paso de corriente, cambio de llanta y gasolina', g:'Asistencia vial', v:['No incluido','No incluido','Hasta 150 (m\u00e1x. anual)','Hasta 150 (m\u00e1x. anual)','No incluido','Hasta 150 (m\u00e1x. anual)','Hasta 150 (m\u00e1x. anual)']}
  ];

  var BENEF=[
    {n:'Alquiler de auto por colisi\u00f3n', g:'Veh\u00edculo y deducible', v:['Hasta 7 d\u00edas','Hasta 10 d\u00edas','Hasta 10 d\u00edas','Hasta 12 d\u00edas','Hasta 10 d\u00edas','Hasta 12 d\u00edas','Hasta 15 d\u00edas']},
    {n:'Reembolso 100% deducible por no culpabilidad', g:'Veh\u00edculo y deducible', v:['No incluido','Incluido','Incluido','Incluido','Incluido','Incluido','Incluido']},
    {n:'Descuento de deducible de colisi\u00f3n', g:'Veh\u00edculo y deducible', v:['No incluido','50% mujeres \u00b7 30% hombres','30%','30%','No incluido','30%','50% mujeres \u00b7 30% hombres']},
    {n:'P\u00e9rdida de efectos personales', g:'Veh\u00edculo y deducible', v:['No incluido','Hasta B/.100','Hasta B/.100','Hasta B/.100','Hasta B/.100','No incluido','Hasta B/.150']},
    {n:'Revisado sin costo', g:'Veh\u00edculo y deducible', v:['No incluido','No incluido','No incluido','No incluido','No incluido','Incluido','Incluido']},
    {n:'Muerte accidental', g:'Salud y vida', v:['B/.5,000 <span class="bsub">· cond. B/.2,500</span>','B/.10,000 <span class="bsub">· cond. B/.5,000</span>','B/.10,000 <span class="bsub">· cond. B/.5,000</span>','B/.10,000 <span class="bsub">· cond. B/.5,000</span>','B/.10,000 <span class="bsub">· cond. B/.5,000</span>','B/.10,000 <span class="bsub">· cond. B/.5,000</span>','B/.15,000 <span class="bsub">· cond. B/.7,500</span>']},
    {n:'Adelanto de gastos m\u00e9dicos por hospitalizaci\u00f3n', g:'Salud y vida', v:['No incluido','Hasta B/.500 (1+4)','Hasta B/.500 (1+4)','Hasta B/.500 (1+4)','No incluido','Hasta B/.750 (1+4)','Hasta B/.1,000 (1+4)']},
    {n:'Defensa Legal', g:'Legal', v:['No incluido','Incluido','Incluido','Incluido','Incluido','Hasta B/.2,000','Incluido']},
    {n:'Defensa Penal', g:'Legal', v:['No incluido','No incluido','Hasta B/.2,000','Hasta B/.2,000','Hasta B/.2,000','Hasta B/.2,000','Hasta B/.3,000']}
  ];

  function scoreVal(s){
    if(!s||s==='No incluido') return -1;
    var nums=s.replace(/,/g,'').match(/\d+/g);
    if(nums){ return Math.max.apply(null,nums.map(Number)); }
    return 0;
  }
  function rowList(items){
    var html='';
    items.forEach(function(it){
      var scores=it.v.map(scoreVal);
      var mx=Math.max.apply(null,scores);
      var wins=[]; if(mx>0){ scores.forEach(function(s,ix){ if(s===mx) wins.push(ix); }); }
      if(wins.length>3) wins=[];
      var rows=INSORD.map(function(k,idx){
        var val=it.v[idx]; var no=(val==='No incluido'||val==='');
        var w=(wins.indexOf(idx)>-1);
        var star=w?'\u2605':'';
        return '<div class="brow'+(w?' win':'')+'"><span class="bk">'+NAMES[k]+'</span><span class="bstar">'+star+'</span><span class="bv'+(no?' no':'')+'">'+(val||'No incluido')+'</span></div>';
      }).join('');
      html+='<details class="bitem"><summary><span class="bn">'+it.n+'</span><span class="bchev">'+CHV_SM+'</span></summary><div class="bbody">'+rows+'</div></details>';
    });
    return '<div class="blist">'+html+'</div>';
  }

  function rsBox(L,asist){
    function pm(x){return price(annualOf(L,x,asist)).a;}
    var ranked=INS.slice().sort(function(a,b){ return (b.cob-a.cob)||(annualOf(L,a,asist)-annualOf(L,b,asist)); });
    var subs=['La m\u00e1s completa \u00b7 mayor cobertura','Muy completa y m\u00e1s econ\u00f3mica que la #1','Buen equilibrio precio-cobertura'];
    var rows=ranked.slice(0,3).map(function(x,ix){
      var hot=(ix===0);
      return '<div class="rk'+(hot?' rk1':'')+'"><div class="rk-n'+(hot?' on':'')+'">'+(ix+1)+'</div>'+
        '<div class="rk-tt"><div class="rk-name">'+NAMES[x.k]+'</div><div class="rk-why">'+subs[ix]+'</div></div>'+
        '<div class="rk-pr"><div class="a">'+pm(x)+'</div><div class="u">x mes</div></div></div>';
    }).join('');
    return '<div class="rs">'+rows+'<div class="rs-note">Puntaje general provisional \u00b7 pendiente de definir</div></div>';
  }

  function render(){
    var root=E(accId);
    root.innerHTML=LEVELS.map(function(L,i){
      var noteText=(opts&&opts.notes&&opts.notes[i]!=null)?opts.notes[i]:(L.note||'');
      var emsg=(opts&&opts.expandMsg)?('<div class="pg2-msg">'+opts.expandMsg+'</div>'):'';
      var asist=st.asist[i]||'sin';
      var filt=(asist==='con')?(st.filt[i]||'precio'):'precio';
      var offers=INS.slice().sort(function(a,b){
        if(filt==='precio') return price(annualOf(L,a,asist)).s-price(annualOf(L,b,asist)).s;
        if(filt==='ded') return (a.col+a.rob)-(b.col+b.rob);
        return metric(b,filt)-metric(a,filt);
      });
      var dp=price(annualOf(L, INS.slice().sort(function(a,b){return price(annualOf(L,a,asist)).s-price(annualOf(L,b,asist)).s;})[0], asist));

      var bdg=L.badge?('<span class="acc-badge '+L.badge.type+'">'+L.badge.t+'</span>'):'';
      var head='<div class="acc-head">'+
          '<div class="acc-tt"><div class="acc-t">'+L.name+'</div><div class="acc-s">Daños a terceros hasta<span class="acc-s-amt">$'+L.cov.dan+'</span><span class="acc-s-note'+(L.nsmall?' sm':'')+'">'+noteText+'</span></div></div>'+
          '<div class="acc-desde"><div class="d">desde</div><div class="p">'+dp.a+'</div><div class="u">'+dp.u+'</div></div>'+CHV+
        '</div>';

      var eOpen=st.exp[i]?' open':'';
      var lOpen=st.cov[i]?' open':'';
      var lims='<div class="lims'+lOpen+'"><button class="lims-h" type="button">Límites a terceros<svg class="chevL" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></button><div class="lims-body">'+
        covRow('Lesiones corporales',L.cov.les)+covRow('Daños a terceros',L.cov.dan)+covRow('Gastos médicos pasajeros',L.cov.med)+
        '<div class="lim2'+eOpen+'"><button class="lim2-hd" type="button">¿Qué significa cada límite?'+CHV3+'</button><div class="lim2-body">'+explBox(L)+'</div></div>'+
      '</div></div>';

      var pay2=(filt==='precio')?('<div class="acc-pay2"><div class="seg acc-pay"><button data-p="m" class="'+(st.pay==='m'?'on':'')+'">10 pagos</button><button data-p="a" class="'+(st.pay==='a'?'on':'')+'">1 pago<span class="pay-tag">Ahorras 5%</span></button></div></div>'):'';

      var asw='<div class="asw"><div class="asw-h">Compara opciones con o sin asistencia</div>'+
        '<div class="asw-opts">'+
          '<div class="asw-opt'+(asist==='sin'?' on':'')+'" data-a="sin">'+(asist==='sin'?CKMARK:'')+'<span class="asw-tag eco">Más económico</span><span class="asw-t">Sin asistencia vial</span><div class="asw-d">Sin grúa.</div></div>'+
          '<div class="asw-opt'+(asist==='con'?' on':'')+'" data-a="con">'+(asist==='con'?CKMARK:'')+'<span class="asw-tag rec">Recomendado</span><span class="asw-t">Con asistencia vial</span><div class="asw-d">Grúa, ambulancia y más.</div></div>'+
        '</div></div>';

      var chips='<div class="cmpf">'+FILTERS.map(function(f){
        return '<button data-f="'+f.k+'" class="'+(filt===f.k?'on':'')+'">'+IC[f.k]+'<span class="fl">'+f.lb+'</span></button>';
      }).join('')+'</div>';
      var cmp=(asist==='con')?('<div class="cmpf-lb">Compara f\u00e1cil precios y beneficios</div>'+chips):'';

      var phead=''; if(filt==='precio'){ phead=(st.pay==='a')?'':'<div class="pl-head"><span class="sp-lg"></span><span class="pl-grow"></span><span class="h-ef">Efectivo</span><span class="h-tj"><span class="tag">−5% con tarjeta</span></span></div>'; }
      var ins; if(filt==='resumen'){ ins=rsBox(L,asist); } else if(filt==='benef'){ ins=rowList(BENEF); } else if(filt==='asist'){ ins=rowList(ASIST); } else { ins='<div class="acc-ins">'+phead+offers.map(function(x){return offerRow(L,x,filt,asist);}).join('')+'</div>'; }
      var open=(i===st.open)?' open':'';
      var nb=L.badge?'':' nobadge';
      return '<div class="acc-card'+open+nb+'" data-i="'+i+'">'+bdg+head+'<div class="acc-body">'+emsg+lims+asw+cmp+pay2+ins+'</div></div>';
    }).join('');

    // abrir/cerrar card
    root.querySelectorAll('.acc-head').forEach(function(h){
      h.onclick=function(){ var i=+h.parentNode.getAttribute('data-i'); st.open=(st.open===i)?-1:i; render(); };
    });
    // explainer "que significa cada limite"
    root.querySelectorAll('.lims-h').forEach(function(b){ b.onclick=function(e){ e.stopPropagation(); var c=b.closest('.acc-card'); var i=+c.getAttribute('data-i'); st.cov[i]=!st.cov[i]; b.parentNode.classList.toggle('open',st.cov[i]); }; });
    root.querySelectorAll('.lim2-hd').forEach(function(b){
      b.onclick=function(e){ e.stopPropagation(); var c=b.closest('.acc-card'); var i=+c.getAttribute('data-i'); st.exp[i]=!st.exp[i]; b.parentNode.classList.toggle('open',st.exp[i]); };
    });
    // ayudita
    root.querySelectorAll('.hlp').forEach(function(h){
      h.querySelector('.hlp-hd').onclick=function(e){ e.stopPropagation(); var c=h.closest('.acc-card'); var i=+c.getAttribute('data-i'); st.help[i]=!st.help[i]; h.classList.toggle('open',st.help[i]); };
    });
    // pago global
    root.querySelectorAll('.acc-pay button').forEach(function(b){
      b.onclick=function(e){ e.stopPropagation(); st.pay=b.getAttribute('data-p'); render(); };
    });
    // filtros
    root.querySelectorAll('.asw-opt').forEach(function(b){ b.onclick=function(e){ e.stopPropagation(); var c=b.closest('.acc-card'); var i=+c.getAttribute('data-i'); st.asist[i]=b.getAttribute('data-a'); render(); }; });
    root.querySelectorAll('.cmpf button').forEach(function(b){
      b.onclick=function(e){ e.stopPropagation(); var c=b.closest('.acc-card'); var i=+c.getAttribute('data-i'); st.filt[i]=b.getAttribute('data-f'); render(); };
    });
    paintGPay();
  }
  function paintGPay(){ var g=document.getElementById(gpayId); if(!g) return; g.querySelectorAll('button').forEach(function(b){ b.className=(b.getAttribute('data-p')===st.pay)?'on':''; }); }
  function init(){ render(); var g=document.getElementById(gpayId); if(g){ g.querySelectorAll('button').forEach(function(b){ b.onclick=function(){ st.pay=b.getAttribute('data-p'); render(); }; }); } paintGPay(); }
    return { init: init };
  }

  function injectImages(){
    document.querySelectorAll('[data-img]').forEach(function(im){
      var k=im.getAttribute('data-img');
      if(k==='hero') im.src=HERO_IMG; else if(k==='brand') im.src=BRAND_IMG;
    });
  }
  function show(pageId){
    var p1=document.getElementById('page1'), p2=document.getElementById('page2');
    p1.hidden=(pageId!=='page1'); p2.hidden=(pageId!=='page2');
    var sc=document.querySelector('.screen'); if(sc) sc.scrollTop=0;
  }
  function wireNav(){
    document.querySelectorAll('[data-go]').forEach(function(b){
      b.addEventListener('click', function(e){ e.stopPropagation(); show(b.getAttribute('data-go')); });
    });
  }
  var PAGE2_OPTS={
    notes:[
      'El precio más bajo en regla',
      'El doble por muy poco más',
      'El equilibrio que más eligen',
      'La mayor tranquilidad'
    ],
    expandMsg:'<b>Mayor límite a terceros</b>, <span class="pg2-hl">más tranquilidad</span>'
  };
  function boot(){
    injectImages();
    makeApp('acc1','gpay1').init();
    makeApp('acc2','gpay2', PAGE2_OPTS).init();
    wireNav();
    show('page1');
  }
  if(document.readyState!=='loading') boot(); else document.addEventListener('DOMContentLoaded',boot);
})();
</script>
