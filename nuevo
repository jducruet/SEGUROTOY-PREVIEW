<script>
  let stack=['screen-home'];
  function setView(btn,view){
    btn.parentElement.querySelectorAll('.vt-btn').forEach(b=>b.classList.remove('on'));
    btn.classList.add('on');
    if(view==='asistencias'){ navTo('screen-benefits'); btn.classList.remove('on'); btn.parentElement.querySelector('.vt-btn').classList.add('on'); }
    else if(view==='limites'){ navTo('screen-limits'); btn.classList.remove('on'); btn.parentElement.querySelector('.vt-btn').classList.add('on'); }
  }
  function closeAllAccordions(){
    document.querySelectorAll('.pcard[data-acc]').forEach(function(c){
      c.classList.remove('open');
      var p=c.querySelector('.pcard-panel');
      if(p) p.style.maxHeight='0px';
    });
  }
  function navTo(id){const cur=stack[stack.length-1];if(cur===id)return;if(cur==='screen-home')closeAllAccordions();const c=document.getElementById(cur);c.classList.remove('active');c.classList.add('behind');const t=document.getElementById(id);t.classList.remove('behind');t.classList.add('active');const s=t.querySelector('.grp-scroll,.home-scroll');if(s)s.scrollTo(0,0);stack.push(id);}
  function navBack(){if(stack.length<2)return;const cur=stack.pop();const prev=stack[stack.length-1];document.getElementById(cur).classList.remove('active');const p=document.getElementById(prev);p.classList.remove('behind');p.classList.add('active');}
  const NAMES={limpio:'B\u00e1sico',completo:'Plus+',premium:'Premium'};
  function goGroup(key){
    var map={tranquilo:'screen-tranquilo',limpio:'screen-limpio',completo:'screen-completo',premium:'screen-premium'};
    if(map[key]){navTo(map[key]);return;}
    document.getElementById('soon-name').textContent = NAMES[key] ? ('Grupo: '+NAMES[key]) : 'Pantalla en construcci\u00f3n';
    navTo('screen-soon');
  }
  function goCoverageHelp(){
    navTo('screen-cov-help');
  }
  function goBuy(insurer){
    document.getElementById('soon-name').textContent = 'Contratar con: '+insurer;
    navTo('screen-soon');
  }

  // selector de vista de pago (anual / mensual) en el home
  function setPayView(btn,mode){
    btn.parentElement.querySelectorAll('button').forEach(function(b){b.classList.remove('on');});
    btn.classList.add('on');
    document.querySelector('.plan-section').setAttribute('data-payview',mode);
  }

  // switch Mensual/Anual en pantallas madre
  function togglePayView(sw){
    var scroll=sw.closest('.grp-scroll');
    var cur=scroll.getAttribute('data-payview')||'mensual';
    var next=(cur==='mensual')?'anual':'mensual';
    scroll.setAttribute('data-payview',next);
    sw.classList.toggle('anual',next==='anual');
    sw.querySelectorAll('.pv-opt').forEach(function(o){
      o.classList.toggle('on', o.getAttribute('data-mode')===next);
    });
  }

  // acorde\u00f3n de las cards de grupo en el home
  document.querySelectorAll('.pcard[data-acc] .pcard-head').forEach(function(head){
    head.addEventListener('click', function(){
      var card = head.closest('.pcard');
      var panel = card.querySelector('.pcard-panel');
      var isOpen = card.classList.contains('open');
      document.querySelectorAll('.pcard[data-acc]').forEach(function(c){
        c.classList.remove('open');
        c.querySelector('.pcard-panel').style.maxHeight = '0px';
      });
      if(!isOpen){
        card.classList.add('open');
        panel.style.maxHeight = panel.scrollHeight + 'px';
      }
    });
  });
  document.querySelectorAll('.seg-btn').forEach(btn=>{btn.addEventListener('click',e=>{e.stopPropagation();document.querySelectorAll('.seg-btn').forEach(b=>{b.classList.remove('on');b.querySelector('svg path').setAttribute('stroke','#7a849c');});btn.classList.add('on');btn.querySelector('svg path').setAttribute('stroke','#fff');});});

  // categorias de la pantalla de beneficios
  const CAT_NAMES={grua:'Gr\u00fada',ambulancia:'Ambulancia',legal:'Asistencia legal',vial:'Asistencia vial'};
  document.querySelectorAll('#catBar .cat').forEach(c=>{c.addEventListener('click',()=>{
    document.querySelectorAll('#catBar .cat').forEach(x=>x.classList.remove('on'));
    c.classList.add('on');
    const cat=c.dataset.cat;
    const titleOrange=document.querySelector('#screen-benefits .bf-comp-title .t-orange');
    const sub=document.querySelector('#screen-benefits .bf-comp-sub');
    const note=document.querySelector('#screen-benefits .gc-note');
    const soon=document.querySelector('#screen-benefits .gc-soon');
    const sets=document.querySelectorAll('#screen-benefits .gc-set');
    const TITLES={grua:'Gr\u00faa',ambulancia:'Ambulancia',legal:'Asistencia Legal',vial:'Asistencia Vial'};
    const SUBS={grua:'Ordenadas de mayor a menor seg\u00fan cantidad de eventos y l\u00edmite por evento.',ambulancia:'Te mostramos cu\u00e1les aseguradoras incluyen traslado en ambulancia.',legal:'Ordenadas de mayor a menor seg\u00fan los montos de defensa que cubren.',vial:'Ordenadas seg\u00fan la cantidad de servicios viales que incluyen.'};
    // hide all sets first
    sets.forEach(x=>x.style.display='none');
    const target=document.querySelector('#screen-benefits .gc-set[data-set="'+cat+'"]');
    if(target){
      target.style.display='';
      soon.style.display='none'; if(sub) sub.style.display='none';
      note.style.display = (cat==='grua') ? '' : 'none';
      titleOrange.innerHTML='Servicios de '+(TITLES[cat]||(CAT_NAMES[cat]||''))+' de<br>cada plan';
    }else{
      soon.style.display=''; if(sub) sub.style.display='none'; note.style.display='none';
      titleOrange.innerHTML='Servicios de '+(CAT_NAMES[cat]||'')+' de<br>cada plan';
    }
    document.querySelector('#screen-benefits .bf-scroll').scrollTop=0;
    var bar=document.getElementById('catBar');
    if(bar){ bar.scrollTo({left: c.offsetLeft - (bar.clientWidth/2) + (c.clientWidth/2), behavior:'smooth'}); }
  });});
</script>
