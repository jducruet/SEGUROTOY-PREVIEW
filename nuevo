<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mockup iPhone — segurotoy</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#1c2541; --gray:#7a849c; --gray-light:#9aa3ba;
    --bg-screen:#f6f6fb; --card:#ffffff; --border:#dfe4f5;
    --brand-blue:#1726c4; --brand-orange:#f4490b;
    --blue:#2f6bff; --blue-soft:#e7eeff;
    --green:#1fb16b; --green-soft:#e4f7ee;
    --orange:#f97316; --orange-soft:#fff0e2;
    --purple:#7c3aed; --purple-soft:#efe8ff;
  }
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
  html,body{height:100%;}
  body{font-family:'Nunito',system-ui,sans-serif;
    background:radial-gradient(1200px 600px at 50% -10%, #eef1ff 0%, transparent 55%),linear-gradient(160deg,#e9ecf6 0%, #dfe3f2 100%);
    display:flex;align-items:center;justify-content:center;min-height:100vh;padding:10px;color:var(--ink);}
  .phone{position:relative;width:390px;height:844px;background:#0b0b10;border-radius:58px;padding:13px;zoom:.84;
    box-shadow:0 0 0 2px #2a2a32,0 40px 80px -30px rgba(20,24,45,.55),0 18px 40px -20px rgba(20,24,45,.4);}
  .phone::before,.phone::after{content:"";position:absolute;left:-3px;background:#16161c;border-radius:3px;}
  .phone::before{top:160px;width:3px;height:34px;box-shadow:0 56px 0 #16161c,0 116px 0 #16161c;}
  .phone::after{top:200px;right:-3px;left:auto;width:3px;height:64px;}
  .screen-area{position:relative;width:100%;height:100%;background:#fff;border-radius:46px;overflow:hidden;}
  .island{position:absolute;top:11px;left:50%;transform:translateX(-50%);width:120px;height:34px;background:#000;border-radius:20px;z-index:60;}
  .statusbar{position:absolute;top:0;left:0;right:0;height:54px;z-index:55;display:flex;align-items:center;justify-content:space-between;
    padding:18px 30px 0;font-size:15px;font-weight:800;color:var(--ink);pointer-events:none;}
  .statusbar .right{display:flex;align-items:center;gap:6px;}
  .home-ind{position:absolute;bottom:8px;left:50%;transform:translateX(-50%);width:134px;height:5px;border-radius:3px;background:#11131c;opacity:.85;z-index:60;}

  .screen{position:absolute;inset:0;display:flex;flex-direction:column;background:#fff;
    transform:translateX(100%);transition:transform .34s cubic-bezier(.4,0,.2,1);z-index:10;}
  .screen.active{transform:translateX(0);z-index:20;}
  .screen.behind{transform:translateX(-22%);z-index:5;}

  .home-scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding-top:54px;background:#fff;}
  .home-scroll::-webkit-scrollbar,.grp-scroll::-webkit-scrollbar,.soon-body::-webkit-scrollbar{display:none;}
  .home-top{display:flex;align-items:center;justify-content:space-between;padding:14px 22px 4px;}
  .logo{display:flex;align-items:center;gap:3px;font-weight:900;font-size:25px;letter-spacing:-1px;}
  .logo .seguro{color:var(--brand-blue);}.logo .toy{color:var(--brand-orange);}
  .burger{background:none;border:none;cursor:pointer;padding:6px;}
  .burger:active{opacity:.5;}
  .hero-copy{padding:18px 20px 0;}
  .hero-copy h1{font-size:31px;line-height:1.05;font-weight:900;letter-spacing:-1.2px;text-align:center;}
  .hero-copy h1 .l1{color:var(--brand-blue);}
  .hero-copy h1 .l2{color:var(--brand-orange);}
  .hero-copy .sub{text-align:center;margin-top:24px;font-size:19px;font-weight:700;color:#16236b;line-height:1.15;}
  .hero-copy .sub b{font-weight:900;}
  .hero-img{display:block;width:90%;max-width:330px;margin:16px auto 0;}

  .docs-strip{margin:2px auto 0;max-width:360px;padding:0 14px 16px;}
  .docs-phrase{text-align:center;font-size:16.5px;font-weight:800;color:#16236b;line-height:1.3;margin-bottom:12px;}
  .docs-phrase b{color:var(--brand-blue);font-weight:900;display:block;margin-top:2px;}
  .docs-row{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;}
  .doc-item{text-align:center;}
  .doc-circle{width:54px;height:54px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 6px;}
  .doc-circle svg{width:28px;height:28px;}
  .doc-circle.dc1{background:#cdd3f7;}
  .doc-circle.dc2{background:#9aa6f0;}
  .doc-circle.dc3{background:var(--brand-blue);}
  .doc-name{font-size:12.5px;font-weight:900;color:var(--brand-blue);line-height:1.15;letter-spacing:-.3px;}

  .plan-section{background:#fff;border-radius:28px 28px 0 0;margin-top:20px;padding:24px 16px 0;}
  .segment{display:flex;background:#eceefb;border-radius:20px;padding:3px;gap:3px;box-shadow:inset 0 1px 3px rgba(28,37,65,.06);margin-bottom:16px;}
  .seg-btn{flex:1;display:flex;align-items:center;justify-content:center;gap:5px;border:none;background:transparent;cursor:pointer;
    font-family:inherit;font-weight:800;font-size:11px;color:var(--gray);padding:6px 6px;border-radius:16px;transition:.22s;white-space:nowrap;}
  .seg-btn svg{width:12px;height:12px;}
  .seg-btn.on{background:linear-gradient(135deg,#2f6bff,#2456e6);color:#fff;box-shadow:0 8px 16px -8px rgba(47,107,255,.7);}
  .seg-btn.on svg path{stroke:#fff;}
  .head{text-align:center;margin-bottom:22px;padding:0 6px;}

  .pay-view{display:flex;gap:4px;background:#eef1f8;border-radius:14px;padding:4px;margin:0 auto 24px;width:100%;max-width:300px;}
  .pay-view button{flex:1;border:none;background:transparent;font-family:inherit;font-weight:900;font-size:12.5px;color:var(--gray);padding:9px 8px;border-radius:11px;cursor:pointer;transition:.18s;white-space:nowrap;text-align:center;}
  .pay-view button.on{background:#fff;color:var(--brand-blue);box-shadow:0 3px 8px -4px rgba(28,37,65,.3);}

  .pp-month{display:none;}
  .plan-section[data-payview="mensual"] .pp-year{display:none;}
  .plan-section[data-payview="mensual"] .pp-pill{display:none;}
  .plan-section[data-payview="mensual"] .pp-month{display:block;}
  .pcard-price .pp-month b{font-size:24px;font-weight:900;color:var(--brand-orange);letter-spacing:-.5px;}
  .pcard-price .pp-month .pp-permo{font-size:11px;font-weight:800;color:var(--brand-orange);display:block;margin-top:1px;}
  .pcard-label{font-size:15px;font-weight:800;color:var(--brand-blue);margin:0 4px 3px;padding-left:2px;letter-spacing:-.2px;line-height:1.2;}
  .pcard-label:not(:first-of-type){margin-top:18px;}
  .head h1{font-size:30px;font-weight:900;letter-spacing:-.8px;line-height:1.12;color:#1c2541;}
  .head h1 .spark{color:var(--brand-orange);}

  /* plan cards — escalera (Opción 1) */
  .pcard{position:relative;background:#fff;border:none;border-radius:18px;margin-bottom:14px;transition:box-shadow .2s;
    box-shadow:0 10px 22px -12px rgba(28,37,65,.30),0 3px 8px -5px rgba(28,37,65,.15);}
  .pcard.feat-blue{box-shadow:0 13px 26px -12px rgba(28,37,65,.34),0 3px 8px -5px rgba(28,37,65,.17);}
  .pcard.feat-orange{box-shadow:0 13px 26px -12px rgba(28,37,65,.34),0 3px 8px -5px rgba(28,37,65,.17);}
  .pcard.has-tag{margin-top:30px;z-index:2;}

  .pcard-head{display:flex;align-items:center;gap:9px;padding:15px 13px;cursor:pointer;transition:transform .14s;}
  .pcard-head:active{transform:scale(.99);}

  .plevel{width:5px;align-self:stretch;min-height:48px;border-radius:3px;flex-shrink:0;}
  .plevel.l1{background:linear-gradient(#9fc4ec,#e3e9f7);}
  .plevel.l2{background:linear-gradient(#5b9be6,#b9d6f5);}
  .plevel.l3{background:linear-gradient(#2f6bff,#8fbbf2);}
  .plevel.l4{background:linear-gradient(#1726c4,#2f6bff);}

  .pcard-info{min-width:0;flex:1;}
  .pcard-kicker{font-size:11px;font-weight:800;color:var(--gray);letter-spacing:.3px;text-transform:uppercase;line-height:1.2;}
  .pcard-name{font-size:22px;font-weight:900;color:var(--brand-blue);letter-spacing:-.5px;line-height:1.05;margin-top:1px;}
  .pcard-count{margin-top:6px;font-size:13px;font-weight:800;color:#9aa3ba;line-height:1.4;}

  .pcard-price{text-align:right;flex-shrink:0;line-height:1.1;}
  .pcard-price .pp-desde{font-size:10px;font-weight:800;color:var(--brand-blue);}
  .pcard-price .pp-year{white-space:nowrap;}
  .pcard-price .pp-year b{font-size:24px;font-weight:900;color:var(--brand-orange);letter-spacing:-.5px;}
  .pcard-price .pp-per{font-size:11px;font-weight:700;color:var(--brand-orange);}
  .pcard-price .pp-pill{display:inline-block;margin-top:6px;font-size:10px;font-weight:900;color:var(--brand-blue);background:var(--blue-soft);border-radius:8px;padding:3px 7px;white-space:nowrap;}

  .pchev{width:18px;height:18px;flex-shrink:0;color:#c2c9da;margin-left:1px;transition:transform .28s;}
  .pcard.open .pchev{transform:rotate(90deg);}

  .pcard-panel{max-height:0;overflow:hidden;transition:max-height .3s ease;}
  .pcard-panel-in{padding:0 15px 14px 27px;}
  .pcard-panel-lbl{font-size:11px;font-weight:900;color:var(--brand-blue);letter-spacing:.3px;text-transform:uppercase;margin:0 0 8px;border-top:1px solid #eef0f7;padding-top:12px;}
  .ins-row{display:flex;align-items:center;gap:9px;padding:8px 0;border-bottom:1px solid #f4f6fb;}
  .ins-row:last-of-type{border-bottom:none;}
  .ins-ico{width:28px;height:28px;border-radius:9px;background:#eef1ff;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
  .ins-ico svg{width:16px;height:16px;}
  .ins-name{font-size:13.5px;font-weight:900;color:#1c2541;}
  .pcard-cta{display:flex;align-items:center;justify-content:center;gap:7px;width:100%;margin-top:13px;border:none;font-family:inherit;font-weight:900;font-size:13.5px;padding:13px;border-radius:13px;cursor:pointer;background:var(--brand-blue);color:#fff;transition:transform .14s;}
  .pcard-cta:active{transform:scale(.98);}
  .pcard-cta svg{width:16px;height:16px;}
  .pcard-cta-note{text-align:center;font-size:14px;font-weight:700;color:#3a4566;margin-top:11px;line-height:1.35;}

  .ptag{position:absolute;top:-12px;left:14px;z-index:10;display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:900;color:#fff;padding:4px 11px;border-radius:12px;letter-spacing:.2px;}
  .ptag svg{width:11px;height:11px;}
  .ptag.blue{background:linear-gradient(135deg,#2f6bff,#1d3fd6);box-shadow:0 6px 14px -6px rgba(47,107,255,.6);}
  .ptag.orange{background:linear-gradient(135deg,#fb8b1e,#f97316);box-shadow:0 6px 14px -6px rgba(249,115,22,.7);}
  .head p{margin-top:6px;font-size:15px;font-weight:800;color:var(--brand-orange);line-height:1.25;}

  .card{position:relative;background:#fff;border:1.6px solid var(--border);border-radius:18px;padding:14px 15px;margin-bottom:13px;cursor:pointer;transition:border-color .2s,box-shadow .2s;}
  .card:active{box-shadow:0 8px 18px -12px rgba(28,37,65,.3);}
  .card.featured{border-color:#f7a85a;background:#fffaf4;}
  .card.has-tag{margin-top:22px;}
  .row-head{display:flex;align-items:flex-start;gap:11px;}
  .icon-wrap{width:42px;height:42px;border-radius:13px;flex-shrink:0;display:flex;align-items:center;justify-content:center;}
  .ic-green{background:var(--green-soft);}.ic-blue{background:var(--blue-soft);}.ic-orange{background:var(--orange-soft);}.ic-purple{background:var(--purple-soft);}
  .icon-wrap svg{width:27px;height:27px;}
  .head-text{flex:1;min-width:0;padding-top:1px;}
  .head-text h3{font-size:18px;font-weight:900;color:var(--brand-blue);letter-spacing:-.4px;line-height:1.1;}
  .head-text .sub{font-size:11.5px;font-weight:600;color:var(--gray);margin-top:3px;line-height:1.25;}
  .expand{width:24px;height:24px;flex-shrink:0;display:flex;align-items:center;justify-content:center;color:#9aa3ba;margin-top:2px;}
  .divider{height:1px;background:#e8ebf6;margin-top:13px;}
  .card.featured .divider{background:#f6e2cf;}
  .row-foot{display:flex;align-items:center;justify-content:space-between;gap:10px;padding-top:12px;}
  .insurers{display:flex;align-items:center;gap:6px;font-size:11.5px;font-weight:700;color:var(--gray);}
  .insurers svg{width:16px;height:16px;flex-shrink:0;}
  .price{text-align:right;line-height:1.05;white-space:nowrap;}
  .price .yr{font-size:11px;font-weight:700;color:var(--gray);}
  .price .yr b{font-size:25px;font-weight:900;color:var(--brand-orange);letter-spacing:-1px;margin:0 1px;}
  .price .yr .per{font-size:11px;}
  .price .day{font-size:12.5px;font-weight:800;color:var(--brand-blue);margin-top:3px;}
  .tag{position:absolute;top:-12px;left:14px;z-index:3;display:inline-flex;align-items:center;gap:4px;font-size:10.5px;font-weight:900;color:#fff;padding:4px 11px;border-radius:12px;}
  .tag svg{width:11px;height:11px;}
  .tag.orange{background:linear-gradient(135deg,#fb8b1e,#f97316);box-shadow:0 6px 14px -6px rgba(249,115,22,.7);}
  .tag.blue{background:linear-gradient(135deg,#2f6bff,#1d3fd6);box-shadow:0 6px 14px -6px rgba(47,107,255,.6);}

  .trust{display:flex;justify-content:space-around;gap:6px;padding:18px 8px 26px;background:#fff;margin-top:4px;}
  .trust .t{display:flex;align-items:center;gap:7px;flex:1;}
  .trust .t svg{width:21px;height:21px;flex-shrink:0;}
  .trust .t b{display:block;font-size:11px;font-weight:800;color:var(--ink);line-height:1.15;}
  .trust .t span{display:block;font-size:9.5px;font-weight:600;color:var(--gray);line-height:1.15;}

  /* ---------- GROUP SCREEN (Voy Seguro) ---------- */
  .grp-top{display:flex;align-items:center;gap:10px;padding:56px 16px 14px;background:#fff;}
  .back-btn{width:38px;height:38px;border-radius:50%;border:none;background:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
  .back-btn:active{transform:scale(.9);background:#f1f3fb;}
  .grp-titlewrap{flex:1;text-align:center;}
  .grp-titlewrap h2{font-size:20px;font-weight:900;color:var(--ink);letter-spacing:-.4px;}
  .grp-sub{font-size:12px;font-weight:700;color:var(--gray);margin-top:3px;}
  .level-pill{display:inline-flex;align-items:center;gap:5px;margin-top:7px;background:var(--blue-soft);color:#2456e6;font-size:12px;font-weight:800;padding:5px 12px;border-radius:20px;}
  .level-pill svg{width:13px;height:13px;}
  .grp-top .spacer{width:38px;flex-shrink:0;}
  .grp-scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;background:var(--bg-screen);padding:18px 16px 26px;}
  .grp-head{display:flex;justify-content:center;align-items:center;margin-bottom:16px;}
  .grp-head h3{font-size:19px;font-weight:900;color:var(--brand-blue);letter-spacing:-.3px;text-align:center;}
  .grp-head p{font-size:12.5px;font-weight:600;color:var(--gray);margin-top:3px;}

  .view-toggle{display:flex;gap:9px;margin-bottom:24px;}
  .vt-btn{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:7px;border:1.5px solid #e6e9f4;background:#fff;cursor:pointer;
    font-family:inherit;font-weight:900;font-size:13px;color:var(--gray);padding:16px 6px;border-radius:15px;transition:.18s;line-height:1.1;text-align:center;}
  .vt-btn svg{width:27px;height:27px;flex-shrink:0;color:#2456e6;}
  .vt-btn:active{transform:scale(.98);}
  .vt-btn.on{background:linear-gradient(135deg,#2333d6,#141fb0);color:#fff;border-color:transparent;box-shadow:0 8px 18px -10px rgba(23,38,196,.6);}
  .vt-btn.on svg{color:#fff;}

  .ins-card{display:flex;align-items:center;gap:9px;background:#fff;border-radius:18px;padding:14px 14px;margin-bottom:11px;cursor:pointer;min-height:64px;
    box-shadow:0 5px 14px -10px rgba(28,37,65,.2);transition:transform .14s;}
  .ins-card:active{transform:scale(.985);}
  .rank{width:24px;height:24px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:900;}
  .rank.top{background:#2456e6;color:#fff;}
  .rank.low{background:#e6e9f2;color:#97a0b5;}
  .ins-logo{flex:1;min-width:0;line-height:1.05;}
  .ins-logo .nm{font-size:15px;font-weight:900;letter-spacing:-.3px;}
  .ins-logo .tl{font-size:8.5px;font-weight:700;color:var(--gray-light);margin-top:1px;}
  .ins-mid{flex:1;min-width:0;}
  .svc-row{display:flex;flex-wrap:wrap;gap:5px;}
  .svc{display:inline-flex;align-items:center;gap:4px;background:#f1f4fb;border:1px solid #e6e9f4;border-radius:9px;
    padding:3px 7px 3px 5px;font-size:9.5px;font-weight:800;color:#4a5575;line-height:1;}
  .svc-ic{width:14px;height:14px;display:flex;align-items:center;justify-content:center;color:#2456e6;flex-shrink:0;}
  .svc-ic svg{width:14px;height:14px;}
  .ins-price{text-align:center;flex-shrink:0;line-height:1.05;}
  .ins-price .from{font-size:9.5px;font-weight:700;color:var(--gray-light);}
  .ins-price .amt{font-size:19px;font-weight:900;color:var(--blue);letter-spacing:-.5px;}
  .ins-price .per{font-size:9.5px;font-weight:700;color:var(--gray-light);}
  .ins-chev{flex-shrink:0;color:#c2c9da;display:flex;align-items:center;}

  /* justified two-line price block */
  .ins-price2{display:flex;flex-direction:column;align-items:flex-end;line-height:1.2;flex-shrink:0;}
  .ins-price2 .pp-mo{font-size:11px;font-weight:700;color:var(--gray-light);text-align:right;white-space:nowrap;}
  .ins-price2 .pp-yr{display:flex;align-items:baseline;gap:3px;}
  .ins-price2 .pp-amt{font-size:21px;font-weight:900;color:var(--blue);letter-spacing:-.5px;}
  .ins-price2 .pp-per{font-size:11px;font-weight:700;color:var(--gray);}
  .ins-price2.single{justify-content:center;}

  /* monthly-form (big) hidden by default; annual sub line hidden by default */
  .ins-price2 .pp-mform{display:none;align-items:baseline;gap:3px;}
  .ins-price2 .pp-mform .pp-amt{color:var(--brand-orange);}
  .ins-price2 .pp-ysub{display:none;font-size:11px;font-weight:700;color:var(--gray-light);text-align:right;white-space:nowrap;}
  /* when screen in monthly mode: show monthly big + annual small, hide annual big + monthly old line */
  .grp-scroll[data-payview="mensual"] .ins-price2 .pp-yr{display:none;}
  .grp-scroll[data-payview="mensual"] .ins-price2 .pp-mo{display:none;}
  .grp-scroll[data-payview="mensual"] .ins-price2 .pp-mform{display:flex;}
  .grp-scroll[data-payview="mensual"] .ins-price2 .pp-ysub{display:block;}

  /* mini switch (Mensual / Anual) */
  .pv-switch{display:flex;align-items:center;justify-content:center;gap:11px;margin:0 0 18px;}
  .pv-switch .pv-opt{font-size:13px;font-weight:900;color:#c2c9da;cursor:pointer;user-select:none;transition:color .18s;}
  .pv-switch .pv-opt.on{color:var(--brand-blue);}
  .pv-switch .pv-track{width:44px;height:24px;border-radius:20px;background:#dfe4f5;position:relative;cursor:pointer;transition:background .2s;flex-shrink:0;}
  .pv-switch .pv-knob{position:absolute;top:2px;left:2px;width:20px;height:20px;border-radius:50%;background:#fff;box-shadow:0 1px 3px rgba(0,0,0,.25);transition:left .2s;}
  .pv-switch.anual .pv-track{background:var(--brand-blue);}
  .pv-switch.anual .pv-knob{left:22px;}

  /* vertical card with payment options */
  .ins-card.col{flex-direction:column;align-items:stretch;gap:0;}
  .ins-head{display:flex;align-items:center;gap:9px;}
  .pay{margin-top:11px;padding-top:11px;border-top:1px solid #f0f2f8;display:flex;align-items:center;justify-content:space-between;gap:10px;}
  .pay-row{display:flex;align-items:center;justify-content:space-between;gap:10px;}
  .pay-cuotas{font-size:13px;font-weight:700;color:#39446b;}
  .pay-cuotas b{color:#1726c4;font-weight:900;}
  .buy-btn{display:inline-flex;align-items:center;justify-content:center;border:1.5px solid #f7c4ac;font-family:inherit;font-weight:900;font-size:12.5px;padding:8px 16px;border-radius:10px;cursor:pointer;background:#fff;color:#d4480f;flex-shrink:0;transition:transform .14s,background .18s;}
  .buy-btn:active{transform:scale(.97);background:#fff4ef;}
  .pay-logos{display:flex;align-items:center;gap:6px;}
